generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WORKER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Department {
  HOUSEKEEPING
  MAINTENANCE
  FRONTDESK
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(WORKER)
  createdAt DateTime @default(now())
}

model Task {
  id           Int         @id @default(autoincrement())
  title        String
  description  String
  status       TaskStatus  @default(PENDING)
  department   Department
  assignedTo   String?
  priority     Priority
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
}